{
  "name": "x-ite-vscode-formatter",
  "publisher": "create3000",
  "displayName": "X_ITE VS Code Formatter",
  "description": "X3D and VRML Formatter for VS Code",
  "version": "2.0.7",
  "license": "MIT",
  "icon": "images/icon.png",
  "homepage": "https://create3000.github.io/x_ite/",
  "author": {
    "name": "Holger Seelig",
    "email": "holger.seelig@gmail.com",
    "url": "https://github.com/create3000"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/create3000/x-ite-vscode-formatter.git"
  },
  "bugs": {
    "url": "https://github.com/create3000/x-ite-vscode-formatter/issues"
  },
  "keywords": [
    "X3D",
    "X3DV",
    "X3DJ",
    "VRML",
    "WRL"
  ],
  "galleryBanner": {
    "color": "#383838",
    "theme": "dark"
  },
  "sponsor": {
    "url": "https://www.patreon.com/X_ITE"
  },
  "main": "./src/extension.js",
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test",
    "release": "node build/release.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.9.3",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "shell-tools": "^1.1.9"
  },
  "dependencies": {
    "x_ite-node": "^2.0.28"
  },
  "extensionPack": [
    "create3000.x-ite-vscode",
    "create3000.x3d-vscode-syntax-highlighting"
  ],
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:x3d",
    "onLanguage:x3dv",
    "onLanguage:x3dj",
    "onLanguage:vrml"
  ],
  "capabilities": {
    "virtualWorkspaces": true
  }
}
